# PostgreSQL
POSTGRES_DB=lvb_portal
POSTGRES_USER=lvb_user
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD

# MinIO
MINIO_ROOT_USER=lvb_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_PASSWORD

# JWT (minimum 32 chars)
JWT_SECRET_KEY=CHANGE_THIS_TO_LONG_RANDOM_STRING_MIN_32_CHARS

# App settings
MAX_FILE_SIZE_MB=50
JWT_EXPIRY_MINUTES=480
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:4000
